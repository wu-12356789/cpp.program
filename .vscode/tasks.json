{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "cppbuild",
            "label": "C/C++: g++.exe 生成活动文件",
            "command": "C:/msys64/ucrt64/bin/g++.exe",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "-I${workspaceFolder}/Header",
                "${file}",
                "-o",
                "${workspaceFolder}/Source/active.exe",
                "-Wl,-subsystem,console"
            ],
            "options": {
                "cwd": "C:/msys64/ucrt64/bin",
                "env": {
                    "TMP": "C:\\temp",
                    "TEMP": "C:\\temp"
                }
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "调试器生成的任务。"
        },
        {
            "type": "shell",
            "label": "Clean: 删除 .exe 文件",
            "command": "del",
            "args": [
                "*.exe"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "silent",
                "focus": false,
                "panel": "shared"
            },
            "detail": "清理旧的 .exe 文件。"
        }
    ]
}